# HTTPS-прокси для доступа по голому IP: браузеры дают микрофон (getUserMedia)
# только secure-контексту, поэтому наружу отдаём https:// c сертификатом
# локального CA Caddy (tls internal). Предупреждение браузера принимается один раз.

{
	# При заходе по голому IP браузер не шлёт SNI — отдаём сертификат IP по умолчанию.
	default_sni 45.135.182.251
}

https://45.135.182.251 {
	tls internal
	reverse_proxy voicechat:8787
}

# Обычный HTTP на 80 порту — редирект на HTTPS.
http://45.135.182.251 {
	redir https://{host}{uri} permanent
}
